# YouTube Clone - Production Environment
# Copy these values into your GitHub Secrets (Settings → Secrets → Actions)
# The GitHub Actions workflow will write the actual .env file during deployment.

APP_NAME="YouTube Clone"
APP_URL=https://yourdomain.com
APP_ENV=production
APP_DEBUG=false
APP_KEY=change-this-to-a-random-64-char-string

DB_DRIVER=mysql
DB_HOST=mysql.yourpanel.com
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/home/youruser/htdocs/storage

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="YouTube Clone"

SESSION_LIFETIME=120
SESSION_SECURE=true

UPLOAD_MAX_SIZE=104857600
VIDEO_MAX_SIZE=1073741824
IMAGE_MAX_SIZE=5242880
