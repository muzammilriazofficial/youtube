{
    "name": "youtube/clone",
    "description": "A full-featured YouTube clone built with PHP, MySQL, and custom MVC framework",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "keywords": [
        "youtube",
        "video-sharing",
        "php",
        "mvc",
        "streaming"
    ]
}
